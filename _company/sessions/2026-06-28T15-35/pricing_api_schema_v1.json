{
  "openapi": "3.0.0",
  "info": {
    "title": "BDS 소상공인플렛폼 — 가격 전략 API 명세서",
    "version": "1.0.0"
  },
  "paths": {
    "/api/pricing-plans": {
      "get": {
        "summary": "현재 유효한 가격 플랜 목록 조회",
        "responses": {
          "200": {
            "description": "플랜 목록 반환",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlanListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/user-journey/{step_id}": {
      "get": {
        "summary": "특정 사용자 여정 단계 조회",
        "parameters": [
          {
            "name": "step_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "단계 정보 및 추천 플랜 반환",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JourneyStepResponse"
                }
              }
            }
          },
          "404": {
            "description": "요청한 단계가 존재하지 않습니다."
          }
        }
      }
    },
    "/api/pricing-recommendation": {
      "get": {
        "summary": "사용자 여정 데이터를 기반으로 최적의 가격 추천 제공",
        "responses": {
          "200": {
            "description": "추천 플랜 및 메시지 반환",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PricingRecommendationResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "사용자 입력 데이터를 기반으로 맞춤형 추천 제공",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PricingRecommendationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "맞춤형 추천 결과 반환",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PricingRecommendationResponse"
                }
              }
            }
          },
          "422": {
            "description": "요청 데이터가 유효하지 않습니다."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PlanListResponse": {
        "type": "object",
        "properties": {
          "plans": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PricingPlan"
            }
          }
        },
        "required": ["plans"]
      },
      "PricingPlan": {
        "type": "object",
        "properties": {
          "plan_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "integer"
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["plan_id", "name", "price", "features"]
      },
      "JourneyStepResponse": {
        "type": "object",
        "properties": {
          "step": {
            "$ref": "#/components/schemas/UserJourneyStep"
          },
          "recommended_plan": {
            "type": "string"
          }
        },
        "required": ["step"]
      },
      "UserJourneyStep": {
        "type": "object",
        "properties": {
          "step_id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": ["step_id", "title", "description"]
      },
      "PricingRecommendationResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "recommended_plan": {
            "$ref": "#/components/schemas/PricingPlan"
          }
        },
        "required": ["message"]
      },
      "PricingRecommendationRequest": {
        "type": "object",
        "properties": {
          "current_step": {
            "type": "integer",
            "default": 1
          },
          "budget": {
            "type": "integer",
            "default": 30000
          }
        },
        "required": []
      }
    }
  }
}